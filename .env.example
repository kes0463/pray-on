# ====================================================
# Pray ON - 환경 변수 템플릿 (.env.example)
# 사용법: 이 파일을 복사해서 ".env" 이름으로 저장한 뒤
#         각 항목의 "여기에_입력" 부분을 실제 값으로 교체하세요.
#         .env 파일은 절대 GitHub에 올리지 마세요!
# ====================================================

# --- OpenAI ---
# 발급처: https://platform.openai.com/api-keys
OPENAI_API_KEY=여기에_OpenAI_API_키_입력

# --- ElevenLabs ---
# 발급처: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=여기에_ElevenLabs_API_키_입력

# ElevenLabs 음성 ID (기본: Rachel - 감성적인 여성 목소리)
# 다른 목소리: https://elevenlabs.io/voice-library 에서 Voice ID 복사
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Flask ---
# 세션 보안을 위한 비밀 키 (아무 랜덤 문자열이나 입력하세요)
# 예시: python -c "import secrets; print(secrets.token_hex(32))" 로 생성
FLASK_SECRET_KEY=여기에_랜덤_비밀키_입력

# --- Firebase ---
# serviceAccountKey.json 파일 경로
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_CREDENTIAL_PATH=serviceAccountKey.json

# Buy Me a Coffee 링크 (본인 계정 URL로 교체)
BUY_ME_A_COFFEE_URL=https://www.buymeacoffee.com/YOUR_NAME
